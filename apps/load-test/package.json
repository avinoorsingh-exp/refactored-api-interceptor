{
	"name": "@exprealty/load-test",
	"version": "0.0.0",
	"private": true,
	"description": "k6 load testing suite for AgentDB endpoints",
	"license": "MIT",
	"scripts": {
		"smoke": "k6 run --out web-dashboard src/scenarios/smoke.js",
		"baseline": "k6 run --out web-dashboard src/scenarios/baseline.js",
		"stress": "k6 run --out web-dashboard src/scenarios/stress.js",
		"agents:smoke": "k6 run --out web-dashboard src/scenarios/agents-smoke.js",
		"agents:baseline": "k6 run --out web-dashboard src/scenarios/agents-baseline.js",
		"agents:stress": "k6 run --out web-dashboard src/scenarios/agents-stress.js",
		"perf:baseline:save": "node scripts/history.mjs save-baseline",
		"perf:run:save": "node scripts/history.mjs save-run",
		"perf:runs": "node scripts/history.mjs list-runs",
		"perf:compare": "node scripts/compare-summaries.mjs",
		"perf:s3:upload": "node scripts/s3.mjs upload-summary",
		"perf:s3:fetch-baseline": "node scripts/s3.mjs fetch-baseline",
		"perf:s3:set-baseline": "node scripts/s3.mjs set-baseline",
		"projections:generate": "node scripts/generate-projections.mjs",
		"k6:agents": "k6 run --out web-dashboard src/scenarios/agents.js",
		"k6:agent-companies": "k6 run --out web-dashboard src/scenarios/agent-companies.js",
		"k6:agent-taxes": "k6 run --out web-dashboard src/scenarios/agent-taxes.js",
		"k6:admin": "k6 run --out web-dashboard src/scenarios/admin.js",
		"k6:companies": "k6 run --out web-dashboard src/scenarios/companies.js",
		"k6:countries": "k6 run --out web-dashboard src/scenarios/countries.js",
		"k6:currencies": "k6 run --out web-dashboard src/scenarios/currencies.js",
		"k6:line-of-business": "k6 run --out web-dashboard src/scenarios/line-of-business.js",
		"k6:metadata": "k6 run --out web-dashboard src/scenarios/metadata.js",
		"k6:mls": "k6 run --out web-dashboard src/scenarios/mls.js",
		"k6:offices": "k6 run --out web-dashboard src/scenarios/offices.js",
		"k6:pay-plans": "k6 run --out web-dashboard src/scenarios/pay-plans.js",
		"k6:regions": "k6 run --out web-dashboard src/scenarios/regions.js",
		"k6:states": "k6 run --out web-dashboard src/scenarios/states.js",
		"k6:all": "pnpm k6:agents && pnpm k6:agent-companies && pnpm k6:agent-taxes && pnpm k6:admin && pnpm k6:companies && pnpm k6:countries && pnpm k6:currencies && pnpm k6:line-of-business && pnpm k6:metadata && pnpm k6:mls && pnpm k6:offices && pnpm k6:pay-plans && pnpm k6:regions && pnpm k6:states"
	},
	"devDependencies": {
		"@faker-js/faker": "^9.3.0"
	}
}
