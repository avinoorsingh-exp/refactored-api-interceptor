{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug Agent Service",
			"type": "node",
			"request": "attach",
			"port": 9229,
			"restart": true,
			"sourceMaps": true,
			"skipFiles": ["<node_internals>/**", "node_modules/**"],
			"preLaunchTask": "Start Agent Service (Debug)",
			"outFiles": ["${workspaceFolder}/services/agent-service/dist/**/*.js"],
			"resolveSourceMapLocations": [
				"${workspaceFolder}/**",
				"!**/node_modules/**"
			]
		},
		{
			"name": "Debug Orchestrator",
			"type": "node",
			"request": "attach",
			"port": 9231,
			"restart": true,
			"sourceMaps": true,
			"skipFiles": ["<node_internals>/**", "node_modules/**"],
			"preLaunchTask": "Start Orchestrator (Debug)",
			"outFiles": ["${workspaceFolder}/services/orchestrator/dist/**/*.js"],
			"resolveSourceMapLocations": [
				"${workspaceFolder}/**",
				"!**/node_modules/**"
			]
		},
		{
			"name": "Attach to Agent Service",
			"type": "node",
			"request": "attach",
			"port": 9229,
			"restart": true,
			"sourceMaps": true,
			"skipFiles": ["<node_internals>/**", "node_modules/**"],
			"outFiles": ["${workspaceFolder}/services/agent-service/dist/**/*.js"]
		},
		{
			"name": "Attach to Orchestrator",
			"type": "node",
			"request": "attach",
			"port": 9231,
			"restart": true,
			"sourceMaps": true,
			"skipFiles": ["<node_internals>/**", "node_modules/**"],
			"outFiles": ["${workspaceFolder}/services/orchestrator/dist/**/*.js"]
		}
	],
	"compounds": [
		{
			"name": "Debug Both Services",
			"configurations": ["Debug Agent Service", "Debug Orchestrator"],
			"stopAll": true
		}
	]
}
