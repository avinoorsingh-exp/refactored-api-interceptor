{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"noImplicitAny": true,
		"allowJs": true,
		"strict": true,
		"allowSyntheticDefaultImports": true,
		"noUncheckedSideEffectImports": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"baseUrl": ".",
		"paths": {
			"@exprealty/api-monitoring": ["packages/api-monitoring/src/index.ts"]
		}
	},
	"include": [
		"packages/api-monitoring/src/**/*.ts",
		"packages/api-monitoring/tests/**/*.ts"
	],
	"exclude": ["**/node_modules", "**/dist"]
}
