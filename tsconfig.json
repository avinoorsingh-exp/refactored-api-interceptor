{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"noImplicitAny": true,
		"allowJs": true,
		"strict": true,
		"allowSyntheticDefaultImports": true,
		"noUncheckedSideEffectImports": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"baseUrl": ".",
		"paths": {
			"@exprealty/api-interceptor": ["packages/api-interceptor/src/index.ts"]
		}
	},
	"include": ["packages/api-interceptor/src/**/*.ts"],
	"exclude": ["**/node_modules", "**/dist"]
}
