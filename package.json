{
    "name": "exprealty",
    "private": true,
    "repository": "https://bitbucket.org/exp-realty/agent-service",
    "license": "MIT",
    "author": "",
    "description": "exprealty — agent-service.",
    "keywords": [],
    "scripts": {
        "build": "pnpm build:packages && pnpm build:services",
        "build:packages": "pnpm -r --filter \"./packages/*\" build",
        "build:services": "pnpm -r --filter \"./services/*\" build",
        "check": "pnpm -r check",
        "db:create": "./scripts/database/create-database.sh",
        "db:reset": "./scripts/reset-database.sh",
        "dev": "./scripts/dev.sh",
        "lint": "pnpm -r lint --no-warn-ignored && pnpm manifests-lint",
        "lint:fix": "pnpm -r lint --fix && prettier --write .",
        "manifests-lint": "pnpm manypkg check",
        "manifests-fix": "pnpm manypkg fix",
        "migration:generate": "pnpm -r --filter \"./packages/database\" migration:generate",
        "migration:run": "pnpm -r --filter \"./packages/database\" migration:run",
        "prepare": "husky",
        "test:unit": "pnpm -r --parallel --filter \"./services/**\" jest -c jest.config.cjs || pnpm -r --filter \"./services/**\" jest -c jest.config.cjs",
        "test:unit:watch": "pnpm -r --filter \"./services/**\" jest -c jest.config.cjs --watch",
        "coverage:unit": "pnpm -r --filter \"./services/**\" jest -c jest.config.cjs --coverage",
        "test:services": "pnpm -r --filter \"./services/*\" test:unit",
        "test:services-coverage": "pnpm -r --filter \"./services/*\" test:coverage",
        "test:services-e2e": "cross-env E2E=1 pnpm -r --filter \"./services/*\" test:e2e",
        "test:coverage": "pnpm -r --filter \"./services/*\" test:coverage",
        "test:e2e": "cross-env E2E=1 pnpm -r --filter \"./services/*\" test:e2e",
        "release:version": "changeset version",
        "release:publish": "changeset publish",
        "test:api": "pnpm -r --filter \"./services/*\" test:api",
        "sync:check": "syncpack list",
        "sync:fix": "syncpack fix",
        "sync:update": "syncpack update"
    },
    "devDependencies": {
        "@babel/core": "^7.28.5",
        "@babel/preset-env": "^7.28.5",
        "@changesets/cli": "^2.27.10",
        "@eslint/js": "^9.28.0",
        "@manypkg/cli": "^0.24.0",
        "@nx/eslint": "21.1.3",
        "@nx/vite": "21.1.3",
        "@nx/web": "21.1.3",
        "@swc/core": "^1.13.5",
        "@swc/jest": "^0.2.39",
        "@types/jest": "^29.5.12",
        "@types/node": "^24.0.0",
        "babel-jest": "^29.7.0",
        "cross-env": "^7.0.3",
        "eslint": "^9.28.0",
        "eslint-config-prettier": "^9.1.2",
        "fast-check": "^4.3.0",
        "husky": "^9.0.11",
        "jest": "^29.7.0",
        "jest-mock-extended": "^4.0.0",
        "jiti": "2.4.2",
        "knip": "^5.60.2",
        "lerna": "^8.2.2",
        "lint-staged": "^15.2.0",
        "msw": "^2.11.6",
        "nx": "21.1.3",
        "prettier": "^3.5.3",
        "prettier-plugin-svelte": "^3.2.0",
        "syncpack": "14.0.0-alpha.13",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.34.0",
        "vite": "^6.0.0"
    },
    "volta": {
        "node": "22.16.0"
    },
    "dependencies": {
        "reflect-metadata": "0.2.2"
    }
}