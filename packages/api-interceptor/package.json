{
	"name": "@exprealty/api-interceptor",
	"version": "0.0.2",
	"description": "NestJS HTTP API interception: structured request/response capture and host callback (no persistence).",
	"type": "module",
	"private": false,
	"keywords": ["nestjs", "api-interceptor", "interceptor", "observability", "http", "exprealty"],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});\"",
		"build": "tsup src/index.ts --format esm --dts",
		"dev": "tsup src/index.ts --format esm --dts --watch",
		"check": "tsc -p tsconfig.json --noEmit",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --max-warnings=0 --fix",
		"test": "node ./scripts/run-jest.cjs",
		"test:full": "pnpm run build && pnpm test",
		"test:watch": "node ./scripts/run-jest.cjs --watch",
		"test:cov": "node ./scripts/run-jest.cjs --coverage",
		"prepublishOnly": "npm run build",
		"pack:check": "npm pack --dry-run"
	},
	"publishConfig": {
		"registry": "https://exprealty-125434132943.d.codeartifact.us-east-1.amazonaws.com/npm/npm-packages/"
	},
	"dependencies": {
		"reflect-metadata": "^0.2.2",
		"@nestjs/common": "^11.0.1",
		"@nestjs/core": "^11.0.1",
		"rxjs": "^7.8.1"
	},
	"devDependencies": {
		"@nestjs/testing": "^11.0.1",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.14",
		"@types/node": "^24.0.0",
		"jest": "^29.7.0",
		"ts-jest": "^29.2.5",
		"tsup": "^8.3.0",
		"typescript": "^5.8.3"
	},
	"repository": "https://bitbucket.org/exp-realty/agent-service/src/main/packages/api-interceptor"
}
