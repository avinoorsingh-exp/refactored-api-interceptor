{
	"name": "@exprealty/encryption",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"dev": "tsup src/index.ts --format esm --dts --watch",
		"check": "tsc -p tsconfig.json --noEmit",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --max-warnings=0 --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"prepublishOnly": "echo 'Workspace-only during MVP' && exit 1"
	},
	"dependencies": {},
	"peerDependencies": {
		"typeorm": "^0.3.0"
	},
	"peerDependenciesMeta": {
		"typeorm": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^24.0.0",
		"tsup": "^8.3.0",
		"typeorm": "^0.3.20",
		"typescript": "^5.8.3"
	},
	"repository": "https://bitbucket.org/exp-realty/agent-service/src/main/packages/encryption"
}
