{
	"name": "@exprealty/logger",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./metrics": {
			"import": "./dist/metrics.js",
			"types": "./dist/metrics.d.ts"
		},
		"./log-tier": {
			"import": "./dist/log-tier.js",
			"types": "./dist/log-tier.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup src/index.ts --format esm --dts --watch",
		"check": "tsc -p tsconfig.json --noEmit",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --max-warnings=0 --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"prepublishOnly": "echo 'Workspace-only during MVP' && exit 1"
	},
	"dependencies": {
		"winston": "^3.15.0",
		"winston-daily-rotate-file": "^5.0.0",
		"winston-transport": "^4.7.0",
		"@nestjs/common": "^11.0.1",
		"@exprealty/config": "workspace:*",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/sdk-metrics": "^1.25.0",
		"@opentelemetry/sdk-node": "^0.52.0",
		"@opentelemetry/resources": "^1.25.0",
		"@opentelemetry/semantic-conventions": "^1.25.0",
		"@opentelemetry/exporter-metrics-otlp-http": "^0.52.0",
		"@opentelemetry/exporter-metrics-otlp-grpc": "^0.52.0",
		"@opentelemetry/exporter-metrics-otlp-proto": "^0.52.0",
		"@opentelemetry/auto-instrumentations-node": "^0.47.0",
		"@opentelemetry/instrumentation-http": "^0.52.0",
		"@opentelemetry/instrumentation-express": "^0.41.0"	
	},
	"devDependencies": {
		"@types/node": "^24.0.0",
		"tsup": "^8.3.0",
		"typescript": "^5.8.3"
	},
	"repository": "https://bitbucket.org/exp-realty/agent-service/src/main/packages/logger"
}
