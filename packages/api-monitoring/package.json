{
	"name": "@exprealty/api-monitoring",
	"version": "0.2.0",
	"description": "NestJS API monitoring: HTTP logging, actor attribution, TypeORM metrics, and read-only admin routes (PostgreSQL).",
	"type": "module",
	"private": false,
	"keywords": ["nestjs", "typeorm", "api-monitoring", "observability", "metrics", "postgresql", "exprealty"],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"dev": "tsup src/index.ts --format esm --dts --watch",
		"check": "tsc -p tsconfig.json --noEmit",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --max-warnings=0 --fix",
		"test": "jest",
		"test:full": "pnpm run build && pnpm test",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"prepublishOnly": "npm run build",
		"pack:check": "npm pack --dry-run"
	},
	"publishConfig": {
		"registry": "https://exprealty-125434132943.d.codeartifact.us-east-1.amazonaws.com/npm/npm-packages/"
	},
	"dependencies": {
		"@nestjs/common": "^11.0.1",
		"@nestjs/core": "^11.0.1",
		"@nestjs/swagger": "^11.2.1",
		"@nestjs/typeorm": "^11.0.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.2",
		"rxjs": "^7.8.1",
		"typeorm": "^0.3.28"
	},
	"devDependencies": {
		"@nestjs/testing": "^11.0.1",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.14",
		"@types/node": "^24.0.0",
		"jest": "^29.7.0",
		"tsup": "^8.3.0",
		"typescript": "^5.8.3"
	},
	"repository": "https://bitbucket.org/exp-realty/agent-service/src/main/packages/api-monitoring"
}
