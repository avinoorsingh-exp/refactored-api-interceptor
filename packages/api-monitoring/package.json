{
	"name": "@exprealty/api-monitoring",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"dev": "tsup src/index.ts --format esm --dts --watch",
		"check": "tsc -p tsconfig.json --noEmit",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --max-warnings=0 --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"prepublishOnly": "echo 'Workspace-only during MVP' && exit 1"
	},
	"dependencies": {
		"@exprealty/cache": "workspace:*",
		"@exprealty/database": "workspace:*",
		"@exprealty/shared-domain": "workspace:*",
		"@nestjs/common": "^10.3.0",
		"@nestjs/core": "^10.3.0",
		"@nestjs/swagger": "^11.2.1",
		"@nestjs/typeorm": "^10.0.1",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.2",
		"rxjs": "^7.8.1",
		"typeorm": "^0.3.20"
	},
	"peerDependencies": {
		"@exprealty/logger": "workspace:*"
	},
	"peerDependenciesMeta": {
		"@exprealty/logger": {
			"optional": false
		}
	},
	"devDependencies": {
		"@exprealty/logger": "workspace:*",
		"@types/express": "^4.17.21",
		"@types/node": "^24.0.0",
		"tsup": "^8.3.0",
		"typescript": "^5.8.3"
	},
	"repository": "https://bitbucket.org/exp-realty/agent-service/src/main/packages/api-monitoring"
}

