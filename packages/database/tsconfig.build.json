{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,

		"rootDir": "./src",
		"outDir": "./dist",
		"baseUrl": ".",
		"paths": {},

		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ESNext",
		"skipLibCheck": true,
		"resolveJsonModule": true
	},
	"include": ["src/**/*"]
}
