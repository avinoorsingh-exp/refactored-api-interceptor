{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "types": ["node", "jest"],
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",                  
    "paths": {
      "@exprealty/*": ["packages/*/src"],
      "@exprealty/logger/metrics": ["packages/logger/src/metrics"],
      "@common/*": ["../src/common/*"],
      "@modules/*": ["../src/modules/*"],
      "@test/*": ["./*"]                 // <-- shared test utils under /test
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "useDefineForClassFields": false
  }
}
