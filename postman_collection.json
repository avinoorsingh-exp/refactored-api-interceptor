			"name": "Countries",
			"item": [
				{
					"name": "POST /countries - AC1: Create with all fields",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201 Created\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has Location header\", function () {",
									"    pm.response.to.have.header('Location');",
									"    const location = pm.response.headers.get('Location');",
									"    pm.expect(location).to.match(/^\\/v1\\/countries\\/[A-Z]{2}$/);",
									"});",
									"",
									"pm.test(\"Response body contains created country\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('alpha2', 'ZZ');",
									"    pm.expect(jsonData).to.have.property('alpha3', 'ZZZ');",
									"    pm.expect(jsonData).to.have.property('number', 999);",
									"    pm.expect(jsonData).to.have.property('name', 'Test Country');",
									"    pm.expect(jsonData).to.have.property('dialingCode', 999);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"alpha2\": \"ZZ\",\n  \"alpha3\": \"ZZZ\",\n  \"number\": 999,\n  \"name\": \"Test Country\",\n  \"dialingCode\": 999\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/countries",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "countries"]
						}
					}
				},
