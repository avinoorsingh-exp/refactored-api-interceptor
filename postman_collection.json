									"    url: pm.environment.get('baseUrl') + '/v1/regions',",
									"    method: 'POST',",
									"    header: { 'Content-Type': 'application/json' },",
									"    body: {",
									"        mode: 'raw',",
									"        raw: JSON.stringify({ name: 'Conflict Test Region' })",
									"    }",
									"}, function (err, response) {",
									"    if (!err) {",
									"        const data = response.json();",
									"        pm.environment.set('conflictRegionId', data.id);",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Conflict Test Region\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/regions/{{testRegionId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "regions", "{{testRegionId}}"]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		}
	]
}
