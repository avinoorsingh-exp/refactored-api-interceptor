                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.meta.limit).to.equal(10);",
                  "    pm.expect(jsonData.meta.offset).to.equal(0);",
                  "});",
                  "pm.test('All results have lifecycleStatus active', function () {",
                  "    const jsonData = pm.response.json();",
                  "    jsonData.data.forEach(m => pm.expect(m.lifecycleStatus).to.equal('active'));",
