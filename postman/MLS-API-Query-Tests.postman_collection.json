    {
      "name": "2. Sorting Tests",
      "item": [
        {
          "name": "Sort by name ASC",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Results are sorted by name ascending', function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.data.length > 1) {",
                  "        const names = jsonData.data.map(m => m.name);",
                  "        const sorted = [...names].sort((a, b) => a.localeCompare(b));",
                  "        pm.expect(names).to.eql(sorted);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/mls?sort={\"conditions\":[{\"field\":\"name\",\"direction\":\"ASC\"}]}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "mls"],
              "query": [
                {"key": "sort", "value": "{\"conditions\":[{\"field\":\"name\",\"direction\":\"ASC\"}]}"}
              ]
            }
