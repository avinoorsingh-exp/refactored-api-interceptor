      "name": "6. Combined Query Tests",
      "item": [
        {
          "name": "Filter + Sort + Pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
