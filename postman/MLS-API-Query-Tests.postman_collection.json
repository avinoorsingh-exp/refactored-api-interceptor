    {
      "name": "4. Filter Tests - Bigint/Integer Columns",
      "description": "Tests for filtering on bigint and integer columns with type-aware casting",
      "item": [
        {
          "name": "Filter id (bigint) EQ - no cast needed",
          "event": [
            {
              "listen": "test",
