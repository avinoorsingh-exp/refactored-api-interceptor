{
  "info": {
    "_postman_id": "mls-api-query-tests",
    "name": "MLS API - Query/Filter/Sort/Search Tests",
    "description": "Comprehensive Postman collection for MLS API testing CRUD, search, filter, and sort capabilities using the JSON query syntax. Tests include bigint/integer field handling and type-aware text search.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "apiVersion",
      "value": "v1",
      "type": "string"
    },
    {
      "key": "mlsId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. CRUD Operations",
      "item": [
        {
          "name": "Create MLS",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has id (bigint)', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.collectionVariables.set('mlsId', jsonData.id);",
                  "});",
                  "pm.test('Response has audit fields', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('created');",
                  "    pm.expect(jsonData).to.have.property('lastModified');",
                  "    pm.expect(jsonData).to.have.property('modifiedBy');",
                  "});",
                  "pm.test('Response has MLS fields', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('name');",
                  "    pm.expect(jsonData).to.have.property('lifecycleStatus');",
                  "    pm.expect(jsonData).to.have.property('orgType');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test MLS {{$timestamp}}\",\n  \"shortName\": \"TMLS\",\n  \"lifecycleStatus\": \"active\",\n  \"orgType\": \"mls\",\n  \"website\": \"https://testmls.example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/mls",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "mls"]
            }
          }
        },
        {
          "name": "Get MLS by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has correct id', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.equal(pm.collectionVariables.get('mlsId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/mls/{{mlsId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "mls", "{{mlsId}}"]
            }
          }
        },
        {
          "name": "Update MLS",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Name is updated', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.name).to.equal('Updated MLS Name');",
                  "});",
                  "pm.test('lastModified is updated', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.lastModified).to.not.equal(jsonData.created);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated MLS Name\",\n  \"shortName\": \"UMLS\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/mls/{{mlsId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "mls", "{{mlsId}}"]
            }
          }
        },
        {
          "name": "Get MLS Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('Response is Problem Details format', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('type');",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "    pm.expect(jsonData.status).to.equal(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/mls/999999999",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "mls", "999999999"]
            }
          }
        },
        {
          "name": "Create Duplicate Name (Conflict)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 409', function () { pm.response.to.have.status(409); });",
                  "pm.test('Response is Problem Details format', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('type');",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "    pm.expect(jsonData.status).to.equal(409);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated MLS Name\",\n  \"lifecycleStatus\": \"active\",\n  \"orgType\": \"mls\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/mls",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "mls"]
            }
          }
        }
      ]
    },
    {
      "name": "1. Pagination Tests",
      "item": [
        {
          "name": "Default Pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has pagination metadata', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData).to.have.property('meta');",
                  "    pm.expect(jsonData.meta).to.have.property('total');",
                  "    pm.expect(jsonData.meta).to.have.property('limit');",
                  "    pm.expect(jsonData.meta).to.have.property('offset');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/mls",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "mls"]
            }
          }
        },
        {
          "name": "Custom Offset and Limit",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Returns correct limit', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.length).to.be.at.most(5);",
                  "    pm.expect(jsonData.meta.limit).to.equal(5);",
                  "    pm.expect(jsonData.meta.offset).to.equal(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/mls?offset=0&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "mls"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "5"}
              ]
            }
          }
        },
        {
          "name": "Page 2",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Offset is correct', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.meta.offset).to.equal(5);",
                  "});"
                ],
