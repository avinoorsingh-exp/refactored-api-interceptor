{
  "info": {
    "_postman_id": "agent-taxes-api-tests",
    "name": "AgentTaxes API - CRUD Tests",
    "description": "Tests for Agent Tax endpoints at /v1/agents/:id/taxes.\n\nFeatures tested:\n- Agent Tax CRUD (list, get by ID, create, update)\n- Tax ID last4 + HMAC token storage (write-only plaintext, masked on read)\n- Masked placeholder rejection (400)\n- Primary tax constraint (only one primary per agent)\n- Validation and error handling",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "agentId",
      "value": "",
      "type": "string",
      "description": "Valid agent UUID - set by setup"
    },
    {
      "key": "taxId",
      "value": "",
      "type": "string",
      "description": "Created agent-tax UUID - set by create test"
    },
    {
      "key": "taxId2",
      "value": "",
      "type": "string",
      "description": "Second agent-tax UUID for primary tests"
    }
  ],
  "item": [
    {
      "name": "0. Setup",
      "item": [
        {
          "name": "Get First Agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Set agentId variable', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var items = jsonData.data || jsonData.items;",
                  "    pm.expect(items).to.be.an('array');",
                  "    pm.expect(items.length).to.be.greaterThan(0);",
                  "    var agentId = items[0].id;",
                  "    pm.collectionVariables.set('agentId', agentId);",
                  "    console.log('Using agent ID:', agentId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/agents?offset=0&limit=1",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "1"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "1. Create Agent Tax",
      "item": [
        {
          "name": "Create Tax (SSN) - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has Location header', function () {",
                  "    pm.response.to.have.header('Location');",
                  "    var location = pm.response.headers.get('Location');",
                  "    pm.expect(location).to.include('/v1/agents/');",
                  "    pm.expect(location).to.include('/taxes/');",
                  "});",
                  "",
                  "pm.test('Response contains agent-tax association', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i);",
                  "    pm.expect(jsonData).to.have.property('agentId');",
                  "    pm.expect(jsonData.agentId).to.equal(pm.collectionVariables.get('agentId'));",
                  "    pm.expect(jsonData).to.have.property('taxId');",
                  "    pm.expect(jsonData).to.have.property('isPrimary', false);",
                  "    pm.collectionVariables.set('taxId', jsonData.taxId);",
                  "});",
                  "",
                  "pm.test('Nested tax has masked value — *****last4, never plaintext', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.tax) {",
                  "        pm.expect(jsonData.tax.value).to.match(/^\\*{5}\\d{4}$/);",
                  "        pm.expect(jsonData.tax.value).to.equal('*****6789');",
                  "        pm.expect(jsonData.tax.taxIdType).to.equal('SSN');",
                  "    }",
                  "});",
                  "",
                  "pm.test('Nested tax has HMAC token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.tax && jsonData.tax.valueToken) {",
                  "        pm.expect(jsonData.tax.valueToken).to.match(/^[0-9a-f]{64}$/);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"taxIdType\": \"SSN\",\n  \"value\": \"123-45-6789\",\n  \"isPrimary\": false\n}"
