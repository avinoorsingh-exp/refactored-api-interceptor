        },
        {
          "name": "Filter by email LIKE",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/companies?offset=0&limit=10&filter={\"conditions\":[{\"field\":\"email\",\"operator\":\"like\",\"value\":\"%@example.com\"}],\"logicalOperator\":\"AND\"}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "companies"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "10"},
                {"key": "filter", "value": "{\"conditions\":[{\"field\":\"email\",\"operator\":\"like\",\"value\":\"%@example.com\"}],\"logicalOperator\":\"AND\"}"}
              ]
            }
          }
        },
