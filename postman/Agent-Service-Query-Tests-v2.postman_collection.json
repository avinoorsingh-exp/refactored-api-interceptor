          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/companies?offset=0&limit=5&sort={\"conditions\":[{\"field\":\"name\",\"direction\":\"ASC\"}]}&filter={\"conditions\":[{\"field\":\"email\",\"operator\":\"like\",\"value\":\"%@%\"}],\"logicalOperator\":\"AND\"}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "companies"],
              "query": [
