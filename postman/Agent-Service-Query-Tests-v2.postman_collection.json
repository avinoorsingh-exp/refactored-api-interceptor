              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "5"},
                {"key": "sort", "value": "{\"conditions\":[{\"field\":\"invalidField\",\"direction\":\"ASC\"}]}"}
              ]
            }
          }
        },
        {
          "name": "Invalid Filter Field (should fail)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=5&filter={\"conditions\":[{\"field\":\"invalidField\",\"operator\":\"eq\",\"value\":\"test\"}],\"logicalOperator\":\"AND\"}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
