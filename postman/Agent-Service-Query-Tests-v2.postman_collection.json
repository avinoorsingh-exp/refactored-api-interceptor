{
  "info": {
    "name": "Agent Service - Query/Filter/Sort/Search Tests",
    "description": "Tests for pagination, filtering, sorting, and search (JIRA AC-1 through AC-6)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Countries - Basic Tests",
      "item": [
        {
          "name": "Pagination (AC-1)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "5"}
              ]
            }
          }
        },
        {
          "name": "Default Sort - name ASC (AC-2)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Search by name (AC-3)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=10&search=test",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "10"},
                {"key": "search", "value": "test"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Countries - Sort Tests",
      "item": [
        {
          "name": "Sort by name DESC",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=5&sort={\"conditions\":[{\"field\":\"name\",\"direction\":\"DESC\"}]}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "5"},
                {"key": "sort", "value": "{\"conditions\":[{\"field\":\"name\",\"direction\":\"DESC\"}]}"}
              ]
            }
          }
        },
        {
          "name": "Sort by alpha2 ASC",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=5&sort={\"conditions\":[{\"field\":\"alpha2\",\"direction\":\"ASC\"}]}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "5"},
                {"key": "sort", "value": "{\"conditions\":[{\"field\":\"alpha2\",\"direction\":\"ASC\"}]}"}
              ]
            }
          }
        },
        {
          "name": "Multi-field Sort (dialingCode ASC, name DESC)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=5&sort={\"conditions\":[{\"field\":\"dialingCode\",\"direction\":\"ASC\"},{\"field\":\"name\",\"direction\":\"DESC\"}]}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "5"},
                {"key": "sort", "value": "{\"conditions\":[{\"field\":\"dialingCode\",\"direction\":\"ASC\"},{\"field\":\"name\",\"direction\":\"DESC\"}]}"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Countries - Filter Tests",
      "item": [
        {
          "name": "Filter dialingCode equals 1",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=10&filter={\"conditions\":[{\"field\":\"dialingCode\",\"operator\":\"eq\",\"value\":1}],\"logicalOperator\":\"AND\"}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "10"},
                {"key": "filter", "value": "{\"conditions\":[{\"field\":\"dialingCode\",\"operator\":\"eq\",\"value\":1}],\"logicalOperator\":\"AND\"}"}
              ]
            }
          }
        },
        {
          "name": "Filter number range (100-200)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=10&filter={\"conditions\":[{\"field\":\"number\",\"operator\":\"gte\",\"value\":100},{\"field\":\"number\",\"operator\":\"lte\",\"value\":200}],\"logicalOperator\":\"AND\"}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "10"},
                {"key": "filter", "value": "{\"conditions\":[{\"field\":\"number\",\"operator\":\"gte\",\"value\":100},{\"field\":\"number\",\"operator\":\"lte\",\"value\":200}],\"logicalOperator\":\"AND\"}"}
              ]
            }
          }
        },
        {
          "name": "Filter name LIKE",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=10&filter={\"conditions\":[{\"field\":\"name\",\"operator\":\"like\",\"value\":\"%United%\"}],\"logicalOperator\":\"AND\"}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "10"},
                {"key": "filter", "value": "{\"conditions\":[{\"field\":\"name\",\"operator\":\"like\",\"value\":\"%United%\"}],\"logicalOperator\":\"AND\"}"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Countries - Combined Tests (AC-4)",
      "item": [
        {
          "name": "Pagination + Sort + Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=5&sort={\"conditions\":[{\"field\":\"name\",\"direction\":\"ASC\"}]}&search=land",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "5"},
                {"key": "sort", "value": "{\"conditions\":[{\"field\":\"name\",\"direction\":\"ASC\"}]}"},
                {"key": "search", "value": "land"}
              ]
            }
          }
        },
        {
          "name": "All Features Combined",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/countries?offset=0&limit=10&filter={\"conditions\":[{\"field\":\"dialingCode\",\"operator\":\"gte\",\"value\":1}],\"logicalOperator\":\"AND\"}&sort={\"conditions\":[{\"field\":\"name\",\"direction\":\"DESC\"}]}&search=a",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "countries"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "10"},
                {"key": "filter", "value": "{\"conditions\":[{\"field\":\"dialingCode\",\"operator\":\"gte\",\"value\":1}],\"logicalOperator\":\"AND\"}"},
                {"key": "sort", "value": "{\"conditions\":[{\"field\":\"name\",\"direction\":\"DESC\"}]}"},
                {"key": "search", "value": "a"}
              ]
            }
          }
        }
      ]
    },
