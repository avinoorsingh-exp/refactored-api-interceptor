                {"key": "sort", "value": "{\"conditions\":[{\"field\":\"name\",\"direction\":\"DESC\"}]}"}
              ]
            }
          }
        },
        {
          "name": "Sort by email ASC",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/companies?offset=0&limit=5&sort={\"conditions\":[{\"field\":\"email\",\"direction\":\"ASC\"}]}",
              "host": ["{{baseUrl}}"],
