        },
        {
          "name": "Search by email domain",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/companies?offset=0&limit=10&search=example.com",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "companies"],
