            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 409', function () { pm.response.to.have.status(409); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Plan Name\",\n  \"active\": true,\n  \"agentPercentage\": 75,\n  \"cap\": 15000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/payplans",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "payplans"]
            }
          }
        }
      ]
