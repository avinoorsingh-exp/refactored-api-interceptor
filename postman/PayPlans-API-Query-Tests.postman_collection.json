    {
      "name": "2. Sorting Tests (AC-2)",
      "item": [
        {
          "name": "AC2.1 - Sort by name ASC",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Results are sorted by name ascending', function () {",
                  "    const jsonData = pm.response.json();",
                  "    const names = jsonData.data.map(p => p.name);",
                  "    const sorted = [...names].sort((a, b) => a.localeCompare(b));",
                  "    pm.expect(names).to.eql(sorted);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/payplans?sort={\"conditions\":[{\"field\":\"name\",\"direction\":\"ASC\"}]}",
