{
  "info": {
    "_postman_id": "payplans-api-query-tests",
    "name": "PayPlans API - Query/Filter/Sort/Search Tests",
    "description": "Comprehensive Postman collection for PayPlans API testing CRUD, search, filter, and sort capabilities using the JSON query syntax.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "apiVersion",
      "value": "v1",
      "type": "string"
    },
    {
      "key": "payPlanId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. CRUD Operations",
      "item": [
        {
          "name": "Create PayPlan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has id', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.collectionVariables.set('payPlanId', jsonData.id);",
                  "});",
                  "pm.test('Response has audit fields', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('created');",
                  "    pm.expect(jsonData).to.have.property('lastModified');",
                  "    pm.expect(jsonData).to.have.property('modifiedBy');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Plan {{$timestamp}}\",\n  \"active\": true,\n  \"agentPercentage\": 80,\n  \"cap\": 16000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/payplans",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "payplans"]
            }
          }
        },
        {
          "name": "Get PayPlan by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has correct id', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.equal(pm.collectionVariables.get('payPlanId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/payplans/{{payPlanId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "payplans", "{{payPlanId}}"]
            }
          }
        },
        {
          "name": "Update PayPlan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Name is updated', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.name).to.equal('Updated Plan Name');",
                  "});",
                  "pm.test('lastModified is updated', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.lastModified).to.not.equal(jsonData.created);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Plan Name\",\n  \"cap\": 20000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/payplans/{{payPlanId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "payplans", "{{payPlanId}}"]
            }
          }
        },
        {
          "name": "Get PayPlan Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', function () { pm.response.to.have.status(404); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/payplans/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "payplans", "00000000-0000-0000-0000-000000000000"]
            }
          }
        },
