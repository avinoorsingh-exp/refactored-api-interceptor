    {
      "name": "2. Sorting Tests",
      "item": [
        {
          "name": "Sort by lastName ASC",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Results are sorted by lastName ascending', function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.data.length > 1) {",
                  "        const names = jsonData.data.map(a => a.lastName);",
                  "        const sorted = [...names].sort((a, b) => a.localeCompare(b));",
                  "        pm.expect(names).to.eql(sorted);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/agents?sort={\"conditions\":[{\"field\":\"lastName\",\"direction\":\"ASC\"}]}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "agents"],
              "query": [
                {"key": "sort", "value": "{\"conditions\":[{\"field\":\"lastName\",\"direction\":\"ASC\"}]}"}
