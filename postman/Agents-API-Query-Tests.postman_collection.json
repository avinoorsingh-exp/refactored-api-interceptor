        },
        {
          "name": "Filter agentId (bigint) LIKE - needs cast to text",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('No PostgreSQL bigint LIKE error', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.not.equal(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/agents?filter={\"conditions\":[{\"field\":\"agentId\",\"operator\":\"like\",\"value\":\"%1%\"}]}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "agents"],
              "query": [
                {"key": "filter", "value": "{\"conditions\":[{\"field\":\"agentId\",\"operator\":\"like\",\"value\":\"%1%\"}]}"}
              ]
            }
          }
