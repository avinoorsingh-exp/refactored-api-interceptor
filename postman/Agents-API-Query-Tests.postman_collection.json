    {
      "name": "4. Filter Tests - Bigint/UUID Columns",
      "description": "Tests for filtering on bigint and UUID columns with type-aware casting",
      "item": [
        {
          "name": "Filter agentId (bigint) EQ - no cast needed",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/agents?filter={\"conditions\":[{\"field\":\"agentId\",\"operator\":\"eq\",\"value\":\"{{agentIdBigint}}\"}]}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "agents"],
              "query": [
                {"key": "filter", "value": "{\"conditions\":[{\"field\":\"agentId\",\"operator\":\"eq\",\"value\":\"{{agentIdBigint}}\"}]}"}
              ]
            }
