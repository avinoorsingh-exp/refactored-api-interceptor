              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/agents?offset=5&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "agents"],
              "query": [
                {"key": "offset", "value": "5"},
                {"key": "limit", "value": "5"}
              ]
            }
          }
        }
      ]
