{
  "info": {
    "_postman_id": "agents-api-query-tests",
    "name": "Agents API - Query/Filter/Sort/Search Tests",
    "description": "Comprehensive Postman collection for Agents API testing CRUD, search, filter, and sort capabilities using the JSON query syntax. Tests include bigint/UUID field handling and type-aware text search.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "apiVersion",
      "value": "v1",
      "type": "string"
    },
    {
      "key": "agentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "agentCompanyId",
      "value": "00000000-0000-0000-0000-000000000001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. CRUD Operations",
      "item": [
        {
          "name": "Create Agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has id (UUID)', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i);",
                  "    pm.collectionVariables.set('agentId', jsonData.id);",
                  "});",
                  "pm.test('Response has agentId (bigint)', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('agentId');",
                  "    pm.collectionVariables.set('agentIdBigint', jsonData.agentId);",
                  "});",
                  "pm.test('Response has audit fields', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('created');",
                  "    pm.expect(jsonData).to.have.property('lastModified');",
                  "    pm.expect(jsonData).to.have.property('modifiedBy');",
                  "});",
                  "pm.test('Response has agent fields', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('firstName');",
                  "    pm.expect(jsonData).to.have.property('lastName');",
                  "    pm.expect(jsonData).to.have.property('lifecycleStatus');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Agent{{$timestamp}}\",\n  \"lifecycleStatus\": \"active\",\n  \"agentCompanyId\": \"{{agentCompanyId}}\",\n  \"seedAgent\": false,\n  \"isStaff\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/agents",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "agents"]
            }
          }
        },
        {
          "name": "Get Agent by ID (UUID)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has correct id', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.equal(pm.collectionVariables.get('agentId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/agents/{{agentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "agents", "{{agentId}}"]
            }
          }
        },
        {
          "name": "Update Agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Name is updated', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.firstName).to.equal('Updated');",
                  "    pm.expect(jsonData.preferredName).to.equal('TestNickname');",
                  "});",
                  "pm.test('lastModified is updated', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.lastModified).to.not.equal(jsonData.created);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated\",\n  \"preferredName\": \"TestNickname\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/agents/{{agentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "agents", "{{agentId}}"]
            }
          }
        },
        {
          "name": "Get Agent Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('Response is Problem Details format', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('type');",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "    pm.expect(jsonData.status).to.equal(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/agents/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "agents", "00000000-0000-0000-0000-000000000000"]
            }
          }
        }
      ]
    },
    {
      "name": "1. Pagination Tests",
      "item": [
        {
          "name": "Default Pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
