  "item": [
    {
      "name": "0. CRUD Operations",
      "item": [
        {
          "name": "Create Office",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has id', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.collectionVariables.set('officeId', jsonData.id);",
                  "});",
                  "pm.test('Response has audit fields', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('created');",
                  "    pm.expect(jsonData).to.have.property('lastModified');",
                  "    pm.expect(jsonData).to.have.property('modifiedBy');",
                  "});",
                  "pm.test('Response has office fields', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('name');",
                  "    pm.expect(jsonData).to.have.property('phone');",
                  "    pm.expect(jsonData).to.have.property('lifecycleStatus');",
                  "    pm.expect(jsonData).to.have.property('companyId');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Office {{$timestamp}}\",\n  \"phone\": \"555-123-4567\",\n  \"lifecycleStatus\": \"active\",\n  \"primaryState\": \"CA\",\n  \"companyId\": \"{{companyId}}\",\n  \"website\": \"https://testoffice.example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/offices",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "offices"]
            }
          }
        },
        {
          "name": "Get Office by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has correct id', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.equal(pm.collectionVariables.get('officeId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/offices/{{officeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "offices", "{{officeId}}"]
            }
          }
        },
        {
          "name": "Update Office",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Name is updated', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.name).to.equal('Updated Office Name');",
                  "});",
                  "pm.test('lastModified is updated', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.lastModified).to.not.equal(jsonData.created);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Office Name\",\n  \"phone\": \"555-999-8888\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/offices/{{officeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "offices", "{{officeId}}"]
            }
          }
        },
        {
          "name": "Get Office Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', function () { pm.response.to.have.status(404); });"
