                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/offices/999999999",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "offices", "999999999"]
            }
          }
        },
