{
  "info": {
    "_postman_id": "offices-api-query-tests",
    "name": "Offices API - Query/Filter/Sort/Search Tests",
    "description": "Comprehensive Postman collection for Offices API testing CRUD, search, filter, and sort capabilities using the JSON query syntax.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "apiVersion",
      "value": "v1",
      "type": "string"
    },
    {
      "key": "officeId",
      "value": "",
      "type": "string"
    },
    {
      "key": "companyId",
      "value": "1",
      "type": "string"
    }
