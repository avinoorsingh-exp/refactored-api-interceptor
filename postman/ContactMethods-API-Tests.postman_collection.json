{
  "info": {
    "name": "ContactMethods API - CRUD & Validation Tests",
    "description": "Tests for ContactMethod nested resource under Agent. Tests CRUD operations, uniqueness constraints, and business rules.\n\nPre-requisite: A valid agent must exist in the database. Set the agentId variable before running tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "agentId",
      "value": "",
      "type": "string",
      "description": "Valid agent UUID - must be set before running tests"
    },
    {
      "key": "contactMethodId",
      "value": "",
      "type": "string",
      "description": "Created contact method ID - set by Create tests"
    },
    {
      "key": "contactMethodId2",
      "value": "",
      "type": "string",
      "description": "Second contact method ID for conflict tests"
    }
  ],
  "item": [
    {
      "name": "Setup - Get Agent ID",
      "item": [
        {
          "name": "Get First Agent (for testing)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has data array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "    pm.expect(jsonData.data.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Set agentId variable', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var agentId = jsonData.data[0].id;",
                  "    pm.collectionVariables.set('agentId', agentId);",
                  "    console.log('Using agent ID:', agentId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/agents?offset=0&limit=1",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "1"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "AC-1: CRUD Operations",
      "item": [
        {
          "name": "Create Contact Method (Email Primary)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has Location header', function () {",
                  "    pm.response.to.have.header('Location');",
                  "});",
                  "",
                  "pm.test('Response contains contact method data', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('name', 'Work Email');",
                  "    pm.expect(jsonData).to.have.property('channel', 'email');",
                  "    pm.expect(jsonData).to.have.property('value', 'test@example.com');",
                  "    pm.expect(jsonData).to.have.property('isPrimary', true);",
                  "    pm.collectionVariables.set('contactMethodId', jsonData.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Work Email\",\n  \"channel\": \"email\",\n  \"subType\": \"work\",\n  \"value\": \"test@example.com\",\n  \"isPrimary\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/agents/{{agentId}}/contactmethods",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents", "{{agentId}}", "contactmethods"]
            }
          }
        },
        {
          "name": "Create Contact Method (Phone Primary)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains phone data', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('channel', 'phone');",
                  "    pm.expect(jsonData).to.have.property('isPrimary', true);",
                  "    pm.collectionVariables.set('contactMethodId2', jsonData.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mobile Phone\",\n  \"channel\": \"phone\",\n  \"subType\": \"mobile\",\n  \"value\": \"+1-555-123-4567\",\n  \"isPrimary\": true,\n  \"smsOptIn\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/agents/{{agentId}}/contactmethods",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents", "{{agentId}}", "contactmethods"]
            }
          }
        },
        {
          "name": "Get Contact Method by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains correct contact method', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.equal(pm.collectionVariables.get('contactMethodId'));",
                  "    pm.expect(jsonData).to.have.property('name');",
                  "    pm.expect(jsonData).to.have.property('channel');",
                  "    pm.expect(jsonData).to.have.property('value');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/agents/{{agentId}}/contactmethods/{{contactMethodId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents", "{{agentId}}", "contactmethods", "{{contactMethodId}}"]
            }
          }
        },
        {
          "name": "List All Contact Methods",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has data array with pagination', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "    pm.expect(jsonData).to.have.property('meta');",
                  "    pm.expect(jsonData.meta).to.have.property('total');",
                  "});",
                  "",
                  "pm.test('Returns created contact methods', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.length).to.be.greaterThan(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/agents/{{agentId}}/contactmethods?offset=0&limit=25",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents", "{{agentId}}", "contactmethods"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "25"}
              ]
            }
          }
        },
        {
