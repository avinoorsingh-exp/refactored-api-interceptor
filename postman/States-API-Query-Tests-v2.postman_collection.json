      "name": "0. Metadata Discovery",
      "item": [
        {
          "name": "List All Entities",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response contains entities array', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('entities');",
                  "    pm.expect(jsonData.entities).to.be.an('array');",
                  "});",
                  "pm.test('States entity is listed', function () {",
                  "    const jsonData = pm.response.json();",
                  "    const states = jsonData.entities.find(e => e.name === 'states');",
                  "    pm.expect(states).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/metadata/entities",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "metadata", "entities"]
            }
          }
        },
        {
          "name": "States - Complete Metadata",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
