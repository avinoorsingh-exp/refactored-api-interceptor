          "name": "AC1 - List Systems for Country (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "    pm.expect(jsonData.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Response has pagination headers', function () {",
                  "    pm.response.to.have.header('X-Total-Count');",
                  "});",
                  "",
                  "pm.test('Each item has expected properties', function () {",
                  "    const jsonData = pm.response.json();",
                  "    jsonData.forEach(function(item) {",
                  "        pm.expect(item).to.have.property('id');",
                  "        pm.expect(item).to.have.property('countryId');",
                  "        pm.expect(item).to.have.property('currencyId');",
                  "        pm.expect(item).to.have.property('description');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Default sort is by id ASC', function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.length >= 2) {",
                  "        const ids = jsonData.map(s => parseInt(s.id));",
                  "        for (let i = 1; i < ids.length; i++) {",
                  "            pm.expect(ids[i]).to.be.at.least(ids[i - 1]);",
                  "        }",
                  "    }",
                  "});",
                  "",
                  "pm.test('Response has correlation ID header', function () {",
                  "    pm.response.to.have.header('X-Correlation-ID');",
                  "});"
                ],
                "type": "text/javascript"
