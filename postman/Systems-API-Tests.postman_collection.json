    {
      "name": "POST - Create System",
      "item": [
        {
          "name": "AC1 - Create System (Success)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate unique description to avoid conflicts",
                  "const timestamp = Date.now();",
                  "const description = `Test System ${timestamp}`;",
                  "pm.collectionVariables.set('createdDescription', description);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has Location header', function () {",
                  "    pm.response.to.have.header('Location');",
                  "    const location = pm.response.headers.get('Location');",
                  "    pm.expect(location).to.match(/\\/v1\\/countries\\/\\d+\\/systems\\/\\d+$/);",
                  "});",
                  "",
                  "pm.test('Response body contains full System representation', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('countryId');",
                  "    pm.expect(jsonData).to.have.property('currencyId');",
                  "    pm.expect(jsonData).to.have.property('description');",
                  "    pm.expect(jsonData).to.have.property('created');",
                  "    pm.expect(jsonData).to.have.property('lastModified');",
                  "    pm.expect(jsonData).to.have.property('modifiedBy');",
                  "    ",
                  "    // Verify values match input",
                  "    pm.expect(jsonData.countryId).to.eql(parseInt(pm.collectionVariables.get('countryId')));",
                  "    pm.expect(jsonData.currencyId).to.eql(parseInt(pm.collectionVariables.get('currencyId')));",
                  "    pm.expect(jsonData.description).to.eql(pm.collectionVariables.get('createdDescription'));",
                  "    ",
                  "    // Store the created system ID for subsequent tests",
                  "    pm.collectionVariables.set('systemId', jsonData.id);",
                  "});",
                  "",
                  "pm.test('Response has correlation ID header', function () {",
                  "    pm.response.to.have.header('X-Correlation-ID');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-ID",
                "value": "{{$guid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currencyId\": {{currencyId}},\n  \"description\": \"{{createdDescription}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/countries/{{countryId}}/systems",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "countries", "{{countryId}}", "systems"]
            },
            "description": "AC1 – Create: Creates a new System and returns 201 Created with the full resource and Location header."
          },
          "response": []
