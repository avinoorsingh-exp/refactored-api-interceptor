	"item": [
		{
			"name": "Setup",
			"item": [
				{
					"name": "Get First Agent (Setup)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has items array', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('items');",
									"    pm.expect(jsonData.items).to.be.an('array');",
									"});",
									"",
									"pm.test('Set agentId variable', function () {",
									"    const jsonData = pm.response.json();",
									"    if (jsonData.items && jsonData.items.length > 0) {",
									"        const agentId = jsonData.items[0].id;",
									"        pm.collectionVariables.set('agentId', agentId);",
									"        console.log('Set agentId to: ' + agentId);",
									"    } else {",
									"        pm.expect.fail('No agents found - create an agent first');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/agents?limit=1",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "agents"],
							"query": [
								{
									"key": "limit",
									"value": "1"
								}
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Create License",
			"item": [
				{
					"name": "Create License - Success",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response has license ID', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData.id).to.be.a('string');",
									"    pm.collectionVariables.set('licenseId', jsonData.id);",
									"    console.log('Created license ID: ' + jsonData.id);",
									"});",
									"",
									"pm.test('Response has correct data', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.number).to.equal('RE-TEST-001');",
									"    pm.expect(jsonData.type).to.equal('Broker');",
									"    pm.expect(jsonData.isPrimary).to.equal(false);",
									"    pm.expect(jsonData.firstName).to.equal('John');",
									"    pm.expect(jsonData.lastName).to.equal('Test');",
									"});",
									"",
									"pm.test('Location header is set', function () {",
									"    pm.response.to.have.header('Location');",
									"    const location = pm.response.headers.get('Location');",
									"    pm.expect(location).to.include('/v1/agents/');",
									"    pm.expect(location).to.include('/licenses/');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
