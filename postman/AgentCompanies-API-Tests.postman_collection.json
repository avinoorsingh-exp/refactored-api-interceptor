        {
          "name": "Create AgentCompany",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has Location header', function () {",
                  "    pm.response.to.have.header('Location');",
                  "    var location = pm.response.headers.get('Location');",
                  "    pm.expect(location).to.include('/v1/agent-companies/');",
                  "});",
                  "",
                  "pm.test('Response contains agent company data', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i);",
                  "    pm.expect(jsonData).to.have.property('name', 'Test Brokerage LLC');",
                  "    pm.expect(jsonData).to.have.property('email');",
                  "    pm.expect(jsonData).to.have.property('phone');",
                  "    pm.expect(jsonData).to.have.property('legacyId');",
                  "    pm.expect(jsonData).to.have.property('useSsn', false);",
                  "    pm.collectionVariables.set('agentCompanyId', jsonData.id);",
                  "});",
                  "",
                  "pm.test('Response has audit timestamps', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('createdAt');",
                  "    pm.expect(jsonData).to.have.property('updatedAt');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"legacyId\": \"{{$timestamp}}\",\n  \"name\": \"Test Brokerage LLC\",\n  \"email\": \"brokerage{{$timestamp}}@example.com\",\n  \"phone\": \"5551234567\",\n  \"useSsn\": false\n}"
            },
            "url": {
