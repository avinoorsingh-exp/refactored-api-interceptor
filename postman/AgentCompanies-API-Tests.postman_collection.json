{
  "info": {
    "_postman_id": "agent-companies-api-tests",
    "name": "AgentCompanies API - CRUD & Association Tests",
    "description": "Tests for AgentCompany entity CRUD operations at /v1/agent-companies and agent-company associations at /v1/agents/:id/agent-companies.\n\nFeatures tested:\n- AgentCompany entity CRUD (list, get, create, update)\n- Agent-Company association management (nested routes)\n- Tax ID encryption and masking\n- Validation and error handling",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
