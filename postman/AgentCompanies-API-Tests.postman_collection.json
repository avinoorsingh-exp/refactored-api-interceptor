                  "    pm.expect(jsonData).to.have.property('agentId');",
                  "    pm.expect(jsonData.agentId).to.equal(pm.collectionVariables.get('agentId'));",
                  "    pm.expect(jsonData).to.have.property('agentCompanyId');",
