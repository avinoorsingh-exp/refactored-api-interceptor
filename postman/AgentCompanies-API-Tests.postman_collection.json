                  "pm.test('Pagination respects limit', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.length).to.be.at.most(5);",
                  "    pm.expect(jsonData.meta.limit).to.equal(5);",
                  "});",
                  "",
                  "pm.test('Pagination metadata is correct', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.meta).to.have.property('offset', 0);",
                  "    pm.expect(jsonData.meta).to.have.property('hasNext');",
                  "    pm.expect(jsonData.meta).to.have.property('hasPrev');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/agent-companies?offset=0&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "agent-companies"],
