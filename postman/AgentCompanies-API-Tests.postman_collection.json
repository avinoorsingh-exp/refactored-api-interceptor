    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "apiVersion",
      "value": "v1",
      "type": "string"
    },
    {
      "key": "agentId",
      "value": "",
      "type": "string",
      "description": "Valid agent UUID - set by setup tests"
    },
    {
      "key": "agentCompanyId",
      "value": "",
      "type": "string",
      "description": "Created agent company ID - set by create tests"
    },
    {
      "key": "agentCompanyId2",
      "value": "",
      "type": "string",
      "description": "Second agent company ID for association tests"
    },
    {
