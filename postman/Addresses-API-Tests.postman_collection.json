    {
      "name": "AC-3: Primary Uniqueness",
      "item": [
        {
          "name": "Conflict - Duplicate Primary Address",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 409 Conflict', function () {",
                  "    pm.response.to.have.status(409);",
                  "});",
                  "",
                  "pm.test('Error message indicates primary exists', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('status', 409);",
                  "    pm.expect(jsonData).to.have.property('title', 'Conflict');",
                  "    pm.expect(jsonData.detail).to.include('primary');",
                  "});",
                  "",
                  "pm.test('Has i18n type for localization', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('type', 'agentaddress.primary_exists');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isPrimary\": true,\n  \"line1\": \"999 Should Fail St\",\n  \"city\": \"Austin\",\n  \"postalCode\": \"78702\"\n}"
            },
