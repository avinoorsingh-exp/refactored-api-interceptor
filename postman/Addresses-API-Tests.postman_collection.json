{
  "info": {
    "name": "Addresses API - CRUD & Validation Tests",
    "description": "Tests for Address nested resource under Agent. Tests CRUD operations, primary uniqueness constraint, and business rules.\n\nPre-requisite: A valid agent must exist in the database. Set the agentId variable before running tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "agentId",
      "value": "",
      "type": "string",
      "description": "Valid agent UUID - must be set before running tests"
    },
    {
      "key": "addressId",
      "value": "",
      "type": "string",
      "description": "Created address ID (BigInt) - set by Create tests"
    },
    {
      "key": "addressId2",
      "value": "",
      "type": "string",
      "description": "Second address ID for additional tests"
    }
  ],
  "item": [
    {
      "name": "Setup - Get Agent ID",
      "item": [
        {
          "name": "Get First Agent (for testing)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has data array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "    pm.expect(jsonData.data.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Set agentId variable', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var agentId = jsonData.data[0].id;",
                  "    pm.collectionVariables.set('agentId', agentId);",
                  "    console.log('Using agent ID:', agentId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/agents?offset=0&limit=1",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "1"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "AC-1: CRUD Operations",
      "item": [
        {
          "name": "Create Address (Primary, Personal)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has Location header', function () {",
                  "    pm.response.to.have.header('Location');",
                  "});",
                  "",
                  "pm.test('Response contains address data', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('agentId');",
                  "    pm.expect(jsonData).to.have.property('addressId');",
                  "    pm.expect(jsonData).to.have.property('isPrimary', true);",
                  "    pm.expect(jsonData).to.have.property('address');",
                  "    pm.expect(jsonData.address).to.have.property('id');",
                  "    pm.expect(jsonData.address).to.have.property('type', 'personal');",
                  "    pm.expect(jsonData.address).to.have.property('role', 'contact');",
                  "    pm.expect(jsonData.address).to.have.property('line1', '123 Main Street');",
                  "    pm.expect(jsonData.address).to.have.property('city', 'Austin');",
                  "    pm.expect(jsonData.address).to.have.property('postalCode', '78701');",
                  "    pm.collectionVariables.set('addressId', jsonData.addressId);",
                  "    console.log('Created address ID:', jsonData.addressId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isPrimary\": true,\n  \"type\": \"personal\",\n  \"role\": \"contact\",\n  \"line1\": \"123 Main Street\",\n  \"line2\": \"Suite 100\",\n  \"city\": \"Austin\",\n  \"unit\": \"A\",\n  \"postalCode\": \"78701\",\n  \"county\": \"Travis\",\n  \"label\": \"Home Address\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/agents/{{agentId}}/addresses",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents", "{{agentId}}", "addresses"]
            }
          }
        },
        {
          "name": "Create Address (Non-Primary, Company)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains company address data', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('addressId');",
                  "    pm.expect(jsonData).to.have.property('isPrimary', false);",
                  "    pm.expect(jsonData.address).to.have.property('type', 'company');",
                  "    pm.expect(jsonData.address).to.have.property('role', 'bill_to');",
                  "    pm.collectionVariables.set('addressId2', jsonData.addressId);",
                  "    console.log('Created address ID 2:', jsonData.addressId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isPrimary\": false,\n  \"type\": \"company\",\n  \"role\": \"bill_to\",\n  \"line1\": \"789 Business Blvd\",\n  \"city\": \"Houston\",\n  \"postalCode\": \"77001\",\n  \"label\": \"Billing Address\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/agents/{{agentId}}/addresses",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents", "{{agentId}}", "addresses"]
            }
          }
        },
        {
          "name": "Get Address by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains correct address', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.addressId).to.equal(pm.collectionVariables.get('addressId'));",
                  "    pm.expect(jsonData).to.have.property('agentId');",
                  "    pm.expect(jsonData).to.have.property('isPrimary');",
                  "    pm.expect(jsonData).to.have.property('address');",
                  "    pm.expect(jsonData.address).to.have.property('line1');",
                  "    pm.expect(jsonData.address).to.have.property('city');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/agents/{{agentId}}/addresses/{{addressId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents", "{{agentId}}", "addresses", "{{addressId}}"]
            }
          }
        },
        {
          "name": "List All Addresses",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has data array with pagination', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "    pm.expect(jsonData).to.have.property('meta');",
                  "    pm.expect(jsonData.meta).to.have.property('total');",
                  "});",
                  "",
                  "pm.test('Returns created addresses', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Primary address appears first', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.length > 1) {",
                  "        pm.expect(jsonData.data[0].isPrimary).to.be.true;",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/agents/{{agentId}}/addresses?offset=0&limit=25",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents", "{{agentId}}", "addresses"],
              "query": [
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "25"}
              ]
            }
          }
        },
        {
          "name": "Update Address",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains updated data', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.address).to.have.property('line1', '456 Updated Street');",
                  "    pm.expect(jsonData.address).to.have.property('city', 'Dallas');",
                  "});",
                  "",
                  "pm.test('lastModified timestamp updated', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.address).to.have.property('lastModified');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"line1\": \"456 Updated Street\",\n  \"city\": \"Dallas\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/agents/{{agentId}}/addresses/{{addressId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "agents", "{{agentId}}", "addresses", "{{addressId}}"]
            }
          }
        }
      ]
    },
