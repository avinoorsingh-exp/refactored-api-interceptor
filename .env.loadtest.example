# ──────────────────────────────────────────────────────────────────
# Load Test Environment Variables
# ──────────────────────────────────────────────────────────────────
# Copy to .env.loadtest.local and customize for your environment.
# Source before running: set -a; source ./.env.loadtest.local; set +a
#
# All vars are optional — safe defaults are used when missing.
# ──────────────────────────────────────────────────────────────────

# ── Target ────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000
ENV=local
# AUTH_MODE=none
# AUTH_TOKEN=
# API_KEY=

# ── k6 Thresholds ────────────────────────────────────────────────
# K6_P95_MS=500
# K6_P99_MS=1500
# K6_ERR_RATE=0.01

# ── Paging ────────────────────────────────────────────────────────
# PAGE_SIZE=25
# PAGE_SIZE_SET=10,25,50,100

# ── Search ────────────────────────────────────────────────────────
# SEARCH_MODE=prefix
# SEARCH_TERMS=alice,bob,charlie,smith,jones
# SEARCH_WEIGHTS=prefix:60,contains:30,exact:10

# ── Includes ──────────────────────────────────────────────────────
# INCLUDES=none
# INCLUDES_WEIGHTS=none:70,light:25,heavy:5

# ── Fields Projection ────────────────────────────────────────────
# FIELDS_MODE=default
# FIELDS_WEIGHTS=default:70,custom:30
# FIELDS_COUNT_SET=8,12,18

# ── Filters ───────────────────────────────────────────────────────
# FILTERS=

# ── Hotspot Endpoints (Phase 5) ───────────────────────────────────
# PERF_HOTSPOT_ENDPOINTS=GET /v1/agents,GET /v1/companies,GET /v1/agent-companies

# ── Regression Comparison (Phase 5) ──────────────────────────────
# PERF_COMPARE=true
# PERF_ENV=local
# REGRESS_P95_PCT=15
# REGRESS_P99_PCT=20
# REGRESS_ERR_ABS=0.005
# REGRESS_HOTSPOT_P95_PCT=20

# ── S3 History (Phase 5) ─────────────────────────────────────────
# PERF_S3_BUCKET=
# PERF_S3_PREFIX=perf/k6
# PERF_S3_REGION=us-east-1

# ── Microscope Mode (Phase 2.1) ──────────────────────────────────
# PERF_QUERY_MODE=off
# PERF_QUERY_SAMPLE_RATE=0.1
# PERF_QUERY_ENDPOINT_ALLOWLIST=
# PERF_QUERY_CAPTURE_EXPLAIN=off
# PERF_QUERY_SLOW_THRESHOLD_MS=100
# PERF_QUERY_CRITICAL_THRESHOLD_MS=500

# ──────────────────────────────────────────────────────────────────
# Module-Specific Overrides
# ──────────────────────────────────────────────────────────────────
# Override any global setting per module using the pattern:
#   <MODULE>_<SETTING>=value
# Module names use uppercase with hyphens replaced by underscores.
#
# Examples:
#   AGENTS_INCLUDES=mix
#   AGENTS_INCLUDES_WEIGHTS=none:50,light:30,heavy:20
#   AGENTS_FIELDS_MODE=mix
#   AGENTS_FIELDS_WEIGHTS=default:60,custom:40
#   AGENTS_FIELDS_COUNT_SET=5,10,15,20
#
#   AGENT_COMPANIES_INCLUDES=none
#   AGENT_COMPANIES_FIELDS_MODE=default
#
#   COMPANIES_FIELDS_MODE=custom
#   COMPANIES_FIELDS_COUNT_SET=3,5,8
# ──────────────────────────────────────────────────────────────────
